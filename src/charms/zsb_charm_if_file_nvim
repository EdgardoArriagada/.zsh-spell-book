#!/usr/bin/env zsh
set -euo pipefail

# (tightly coupled with tmux config, ripgrep, and nvim)
# for tmux conf, see https://github.com/EdgardoArriagada/dotFiles/blob/main/tmux/home/.tmux.conf

local lines=("${(@f)*}")
local filename=${lines[1]}

if [[ ! -f $filename ]]
  then exit 1
fi

function loadFile() {
  case ${1:e} in
    rs) export PATH=$PATH:~/.cargo/bin ;;
    js|ts|jsx|tsx|mjs|cjs) eval "$(fnm env --use-on-cd)" ;;
    py) eval "$(pyenv init -)"; $(poetry env activate) ;;
  esac

  case $# in
    1) nvim $1 ;;
    2) nvim $1 +${2} -c 'normal zz' ;;
  esac
}

local lastLine=${lines[-2]}

if [[ -f "$lastLine" ]]
  then loadFile $filename; exit 0
fi

# get number out of first number until ':' in a line using param expansion
local lineNumber=${lastLine%%:*}

# check if number is valid
[[ $lineNumber != <-> ]] && exit 1

loadFile $filename $lineNumber

exit 0
