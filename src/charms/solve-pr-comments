#!/usr/bin/env bun

import { $ } from "bun";

const repo = (await $`gh repo view --json nameWithOwner --jq '.nameWithOwner'`.text()).trim();
console.log(`=> Repo: ${repo}`);

console.log("=> Fetching PR number...");
const prNum = parseInt((await $`gh pr view --json number --jq '.number'`.text()).trim());
console.log(`=> PR #${prNum}`);

console.log("=> Fetching unresolved review threads and general comments...");
const [owner, repoName] = repo.split("/");

const result = await $`gh api graphql -f query=${`
  query($owner: String!, $repo: String!, $pr: Int!) {
    repository(owner: $owner, name: $repo) {
      pullRequest(number: $pr) {
        reviewThreads(first: 100) {
          nodes {
            id
            isResolved
            isOutdated
            path
            line
            comments(first: 10) {
              nodes {
                body
                author { login }
                createdAt
              }
            }
          }
        }
        comments(first: 100) {
          nodes {
            body
            author { login }
            createdAt
          }
        }
      }
    }
  }
`} -f owner=${owner} -f repo=${repoName} -F pr=${prNum}`.json();

const pr = result.data.repository.pullRequest;

type ReviewThreadItem = {
  kind: "thread";
  id: string;
  path: string;
  line: string;
  comments: string;
};

type GeneralCommentItem = {
  kind: "comment";
  comments: string;
};

type Item = ReviewThreadItem | GeneralCommentItem;

const unresolvedThreads: Item[] = (pr.reviewThreads.nodes as any[])
  .filter((t) => !t.isResolved && !t.isOutdated)
  .map((t) => ({
    kind: "thread" as const,
    id: t.id,
    path: t.path,
    line: t.line ?? "N/A",
    comments: (t.comments.nodes as any[])
      .map((c: any) => `**${c.author.login}:** ${c.body}`)
      .join("\n"),
  }));

const generalComments: Item[] = (pr.comments.nodes as any[]).map((c) => ({
  kind: "comment" as const,
  comments: `**${c.author.login}:** ${c.body}`,
}));

const items: Item[] = [...unresolvedThreads, ...generalComments];
const total = items.length;

if (total === 0) {
  console.log("=> No review comments found. Nothing to do.");
  process.exit(0);
}

console.log(
  `=> Found ${unresolvedThreads.length} unresolved review thread(s) and ${generalComments.length} general comment(s).`
);

console.log("=> Fetching PR diff...");
const prDiff = await $`gh pr diff ${prNum}`.text();

async function askUser(question: string): Promise<string> {
  process.stdout.write(question);
  return new Promise<string>((resolve) => {
    process.stdin.resume();
    process.stdin.setEncoding("utf8");
    process.stdin.once("data", (data) => {
      process.stdin.pause();
      resolve((data as string).trim().toLowerCase());
    });
  });
}

async function runClaude(prompt: string): Promise<void> {
  const proc = Bun.spawn(
    [
      "claude",
      "--dangerously-skip-permissions",
      "--print",
      prompt,
      "--model",
      "sonnet",
      "--allowedTools",
      "Read,Edit,Write,Bash(git diff:*),Bash(git log:*),Bash(git status:*),Grep",
    ],
    { stdout: "pipe", stderr: "inherit" }
  );

  const reader = proc.stdout.getReader();
  const decoder = new TextDecoder();
  let buffer = "";

  while (true) {
    const { done, value } = await reader.read();
    if (done) break;
    buffer += decoder.decode(value, { stream: true });
    const lines = buffer.split("\n");
    buffer = lines.pop() ?? "";
    for (const line of lines) console.log(`  ${line}`);
  }
  if (buffer) console.log(`  ${buffer}`);

  await proc.exited;
}

function extractFileDiff(fullDiff: string, filePath: string): string {
  const sections = fullDiff.split(/(?=^diff --git )/m);
  const match = sections.find((s) => s.includes(`b/${filePath}`));
  return match ?? `(no diff found for ${filePath})`;
}

for (let i = 0; i < total; i++) {
  const item = items[i];

  console.log("");
  console.log("============================================");

  let prompt: string;

  if (item.kind === "thread") {
    console.log(`=> [${i + 1}/${total}] Inline thread on ${item.path}:${item.line}`);
    console.log("=> Comments:");
    console.log(item.comments);
    console.log("============================================");

    const answer = await askUser("=> Resolve this thread? [Y/n] ");
    if (answer === "n" || answer === "no") {
      console.log("=> Skipped.");
      continue;
    }

    let fileContent = "";
    const file = Bun.file(item.path);
    if (await file.exists()) {
      fileContent = await file.text();
    }

    const fileDiff = extractFileDiff(prDiff, item.path);

    prompt = `# Role
You are an expert Senior Staff Software Engineer. You possess deep expertise in automated code refactoring, software architecture, and root cause analysis.

# Context
You are resolving code review feedback on Pull Request #${prNum} in the repository ${repo}.

## Review Thread
- **File:** ${item.path}
- **Line:** ${item.line}

### Reviewer Comments
${item.comments}

### Current File Content
\`\`\`
${fileContent}
\`\`\`

### Relevant PR Diff
${fileDiff}

# Task
Implement a robust engineering solution based on the feedback received from the review comment.

## Analysis & Resolution Steps
1. **Analyze the Claim:** Examine the feedback in the context of the codebase and the diff.
2. **Critically Evaluate (Mandatory):**
   - **Verify Validity:** Do not assume the comment is factually correct. Challenge the premise.
   - **Check Constraints:** Ensure the suggested change does not violate existing logic or introduce regressions.
3. **Determine the Solution:**
   - If the issue is valid, identify the **root cause**.
   - **Solve, Don't Just Obey:** If the comment suggests a specific implementation that is suboptimal, insecure, or hacky, ignore the suggestion and implement the **industry-standard best practice**.
   - If the comment is invalid or already addressed, explain why and skip the change.
4. **Implement:** Apply the specific code changes to the codebase.

# Constraints
- Prioritize code stability and system integrity over blind compliance to the reviewer's specific instructions.
- Only modify the file(s) relevant to the feedback. Do not refactor unrelated code.

# Output Format
1. **Logic Verification:** A brief analysis (2-3 lines) explaining whether the comment was valid and why you chose the specific solution.
2. **Code Fix:** Apply the necessary changes to the codebase.`;
  } else {
    console.log(`=> [${i + 1}/${total}] General PR comment`);
    console.log("=> Comment:");
    console.log(item.comments);
    console.log("============================================");

    const answer = await askUser("=> Address this comment? [Y/n] ");
    if (answer === "n" || answer === "no") {
      console.log("=> Skipped.");
      continue;
    }

    prompt = `# Role
You are an expert Senior Staff Software Engineer. You possess deep expertise in automated code refactoring, software architecture, and root cause analysis.

# Context
You are resolving general PR feedback on Pull Request #${prNum} in the repository ${repo}.
This comment is not tied to a specific file or line — it is a high-level review comment about the PR as a whole.

### Reviewer Comment
${item.comments}

### Relevant PR Diff
${prDiff}

# Task
Implement a robust engineering solution based on the feedback received from the review comment.

## Analysis & Resolution Steps
1. **Analyze the Claim:** Examine the feedback in the context of the codebase and the diff.
2. **Critically Evaluate (Mandatory):**
   - **Verify Validity:** Do not assume the comment is factually correct. Challenge the premise.
   - **Check Constraints:** Ensure the suggested change does not violate existing logic or introduce regressions.
3. **Determine the Solution:**
   - If the issue is valid, identify the **root cause** and which file(s) need to change.
   - **Solve, Don't Just Obey:** If the comment suggests a specific implementation that is suboptimal, insecure, or hacky, ignore the suggestion and implement the **industry-standard best practice**.
   - If the comment is invalid or already addressed, explain why and skip the change.
4. **Implement:** Apply the specific code changes to the codebase.

# Constraints
- Prioritize code stability and system integrity over blind compliance to the reviewer's specific instructions.
- Only modify the file(s) relevant to the feedback. Do not refactor unrelated code.

# Output Format
1. **Logic Verification:** A brief analysis (2-3 lines) explaining whether the comment was valid and why you chose the specific solution.
2. **Code Fix:** Apply the necessary changes to the codebase.`;
  }

  await runClaude(prompt);

  if (item.kind === "thread") {
    const resolveAnswer = await askUser("=> Mark this thread as resolved on GitHub? [Y/n] ");
    if (resolveAnswer !== "n" && resolveAnswer !== "no") {
      try {
        const resolveResult = await $`gh api graphql -f query=${`
          mutation($threadId: ID!) {
            resolveReviewThread(input: { threadId: $threadId }) {
              thread {
                isResolved
              }
            }
          }
        `} -f threadId=${item.id}`.json();
        if (resolveResult.data?.resolveReviewThread?.thread?.isResolved) {
          console.log("=> Thread marked as resolved on GitHub.");
        } else {
          console.log("=> Warning: could not resolve thread on GitHub.");
        }
      } catch (err) {
        console.log(`=> Warning: failed to resolve thread on GitHub: ${err}`);
      }
    }
  }

  console.log("");
  console.log(`=> Done with item [${i + 1}/${total}].`);
}

console.log("");
console.log(`=> All ${total} item(s) processed.`);
console.log("=> Review the changes and commit when ready.");
