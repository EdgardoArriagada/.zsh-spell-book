#!/usr/bin/env bun

import { $ } from "bun";
import * as readline from "readline";

// --- Constants ---

const CLAUDE_ALLOWED_TOOLS = [
  "Read",
  "Edit",
  "Write",
  "Bash(git diff:*)",
  "Bash(git log:*)",
  "Bash(git status:*)",
  "Grep",
].join(",");

const SEPARATOR = "=".repeat(44);

// --- Types ---

interface RawComment {
  body: string;
  author: { login: string };
  createdAt: string;
}

interface RawThread {
  id: string;
  isResolved: boolean;
  isOutdated: boolean;
  path: string;
  line: number | null;
  originalLine: number | null;
  comments: {
    pageInfo: { hasNextPage: boolean };
    nodes: RawComment[];
  };
}

type ReviewThreadItem = {
  kind: "thread";
  id: string;
  path: string;
  line: number | null;
  comments: string;
};

type GeneralCommentItem = {
  kind: "comment";
  comments: string;
};

type Item = ReviewThreadItem | GeneralCommentItem;

type PRContext = {
  num: number;
  repo: string;
  diff: string;
};

// --- Helpers ---

const rl = readline.createInterface({ input: process.stdin, output: process.stdout });

async function confirmUser(question: string): Promise<boolean> {
  return new Promise((resolve) => {
    rl.question(question, (answer) => {
      const a = answer.trim().toLowerCase();
      resolve(a !== "n" && a !== "no");
    });
  });
}

async function runClaude(prompt: string): Promise<void> {
  const proc = Bun.spawn(
    [
      "claude",
      "--dangerously-skip-permissions",
      "--print",
      prompt,
      "--model",
      "sonnet",
      "--allowedTools",
      CLAUDE_ALLOWED_TOOLS,
    ],
    { stdout: "pipe", stderr: "inherit", stdin: "ignore" }
  );

  let buffer = "";
  for await (const chunk of proc.stdout) {
    buffer += Buffer.from(chunk).toString("utf8");
    const lines = buffer.split("\n");
    buffer = lines.pop() ?? "";
    for (const line of lines) console.log(`  ${line}`);
  }
  if (buffer) console.log(`  ${buffer}`);

  await proc.exited;
  if (proc.exitCode !== 0) {
    console.warn(`=> Warning: Claude exited with code ${proc.exitCode} for this thread. Changes may be incomplete.`);
  }
}

function extractFileDiff(fullDiff: string, filePath: string): string {
  const sections = fullDiff.split(/(?=^diff --git )/m);
  const match = sections.find((s) => s.includes(`b/${filePath}`));
  return match ?? `(no diff found for ${filePath})`;
}

function buildPrompt(contextBlock: string): string {
  return `# Role
You are an expert Senior Staff Software Engineer. You possess deep expertise in automated code refactoring, software architecture, and root cause analysis.

# Context
${contextBlock}

# Task
Implement a robust engineering solution based on the feedback received from the review comment.

## Analysis & Resolution Steps
1. **Analyze the Claim:** Examine the feedback in the context of the codebase and the diff.
2. **Critically Evaluate (Mandatory):**
   - **Verify Validity:** Do not assume the comment is factually correct. Challenge the premise.
   - **Check Constraints:** Ensure the suggested change does not violate existing logic or introduce regressions.
3. **Determine the Solution:**
   - If the issue is valid, identify the **root cause** and which file(s) need to change.
   - **Solve, Don't Just Obey:** If the comment suggests a specific implementation that is suboptimal, insecure, or hacky, ignore the suggestion and implement the **industry-standard best practice**.
   - If the comment is invalid or already addressed, explain why and skip the change.
4. **Implement:** Apply the specific code changes to the codebase.

# Constraints
- Prioritize code stability and system integrity over blind compliance to the reviewer's specific instructions.
- Only modify the file(s) relevant to the feedback. Do not refactor unrelated code.

# Output Format
1. **Logic Verification:** A brief analysis (2-3 lines) explaining whether the comment was valid and why you chose the specific solution.
2. **Code Fix:** Apply the necessary changes to the codebase.`;
}

async function resolveThreadOnGitHub(threadId: string): Promise<boolean> {
  try {
    const result = await $`gh api graphql -f query=${`
      mutation($threadId: ID!) {
        resolveReviewThread(input: { threadId: $threadId }) {
          thread {
            isResolved
          }
        }
      }
    `} -f threadId=${threadId}`.json();
    return result.data?.resolveReviewThread?.thread?.isResolved === true;
  } catch {
    return false;
  }
}

async function buildContext(item: Item, ctx: PRContext): Promise<string> {
  if (item.kind === "thread") {
    const file = Bun.file(item.path);
    const fileContent = (await file.exists()) ? await file.text() : "";
    const fileDiff = extractFileDiff(ctx.diff, item.path);
    const lineContext = item.line != null
      ? `**Line:** ${item.line}`
      : `**Scope:** Entire file (no specific line)`;

    return `You are resolving code review feedback on Pull Request #${ctx.num} in the repository ${ctx.repo}.

## Review Thread
- **File:** ${item.path}
- ${lineContext}

### Reviewer Comments
${item.comments}

### Current File Content
\`\`\`
${fileContent}
\`\`\`

### Relevant PR Diff
${fileDiff}`;
  }

  return `You are resolving general PR feedback on Pull Request #${ctx.num} in the repository ${ctx.repo}.
This comment is not tied to a specific file or line — it is a high-level review comment about the PR as a whole.

### Reviewer Comment
${item.comments}

### Relevant PR Diff
${ctx.diff}`;
}

async function processItem(item: Item, index: number, total: number, ctx: PRContext): Promise<void> {
  console.log();
  console.log(SEPARATOR);

  const label = item.kind === "thread"
    ? `Thread on ${item.line != null ? `${item.path}:${item.line}` : item.path}`
    : "General PR comment";

  console.log(`=> [${index + 1}/${total}] ${label}`);
  console.log(item.kind === "thread" ? "=> Comments:" : "=> Comment:");
  console.log(item.comments);
  console.log(SEPARATOR);

  const actionLabel = item.kind === "thread" ? "Resolve this thread" : "Address this comment";
  if (!await confirmUser(`=> ${actionLabel}? [Y/n] `)) {
    console.log("=> Skipped.");
    return;
  }

  await runClaude(buildPrompt(await buildContext(item, ctx)));

  if (item.kind === "thread") {
    if (await confirmUser("=> Mark this thread as resolved on GitHub? [Y/n] ")) {
      const resolved = await resolveThreadOnGitHub(item.id);
      if (resolved) {
        console.log("=> Thread marked as resolved on GitHub.");
      } else {
        console.warn("=> Warning: could not resolve thread on GitHub.");
      }
    }
  }

  console.log();
  console.log(`=> Done with item [${index + 1}/${total}].`);
}

// --- Main ---

async function main(): Promise<void> {
  let repo: string;
  try {
    repo = (await $`gh repo view --json nameWithOwner --jq '.nameWithOwner'`.text()).trim();
  } catch {
    console.error("=> Error: could not determine repo. Are you inside a GitHub repository?");
    process.exit(1);
  }
  console.log(`=> Repo: ${repo}`);

  console.log("=> Fetching PR number...");
  let prNum: number;
  try {
    const raw = (await $`gh pr view --json number --jq '.number'`.text()).trim();
    prNum = parseInt(raw);
    if (!Number.isFinite(prNum) || prNum <= 0) throw new Error("invalid PR number");
  } catch {
    console.error(
      "=> Error: could not parse a valid PR number from `gh pr view`.\n" +
      "   Make sure you are on a branch with an open PR and that `gh auth status` is authenticated."
    );
    process.exit(1);
  }
  console.log(`=> PR #${prNum}`);

  console.log("=> Fetching unresolved review threads and general comments...");
  const [owner, repoName] = repo.split("/");

  const threadsResult = await $`gh api graphql -f query=${`
    query($owner: String!, $repo: String!, $pr: Int!) {
      repository(owner: $owner, name: $repo) {
        pullRequest(number: $pr) {
          reviewThreads(first: 100) {
            pageInfo { hasNextPage }
            nodes {
              id
              isResolved
              isOutdated
              path
              line
              originalLine
              comments(first: 10) {
                pageInfo { hasNextPage }
                nodes {
                  body
                  author { login }
                  createdAt
                }
              }
            }
          }
          comments(first: 100) {
            nodes {
              body
              author { login }
              createdAt
            }
          }
        }
      }
    }
  `} -f owner=${owner} -f repo=${repoName} -F pr=${prNum}`.json();

  if (threadsResult.errors?.length) {
    console.error("=> GraphQL error fetching review threads:");
    for (const e of threadsResult.errors) console.error("  ", e.message);
    process.exit(1);
  }

  const pr = threadsResult.data.repository.pullRequest;

  if (pr.reviewThreads.pageInfo.hasNextPage) {
    console.warn("=> Warning: this PR has more than 100 review threads. Only the first 100 will be processed.");
  }

  for (const thread of pr.reviewThreads.nodes as RawThread[]) {
    if (thread.comments.pageInfo.hasNextPage) {
      console.warn(`=> Warning: thread on ${thread.path} has more than 10 comments. Only the first 10 are included in the prompt.`);
    }
  }

  const unresolvedThreads: Item[] = (pr.reviewThreads.nodes as RawThread[])
    .filter((t) => !t.isResolved && !t.isOutdated)
    .map((t) => ({
      kind: "thread" as const,
      id: t.id,
      path: t.path,
      line: t.line ?? t.originalLine ?? null,
      comments: t.comments.nodes
        .map((c) => `**${c.author.login}:** ${c.body}`)
        .join("\n"),
    }));

  const generalComments: Item[] = (pr.comments.nodes as RawComment[]).map((c) => ({
    kind: "comment" as const,
    comments: `**${c.author.login}:** ${c.body}`,
  }));

  const items: Item[] = [...unresolvedThreads, ...generalComments];

  if (items.length === 0) {
    console.log("=> No review comments found. Nothing to do.");
    process.exit(0);
  }

  console.log(
    `=> Found ${unresolvedThreads.length} unresolved review thread(s) and ${generalComments.length} general comment(s).`
  );

  console.log("=> Fetching PR diff...");
  const ctx: PRContext = {
    num: prNum,
    repo,
    diff: await $`gh pr diff ${prNum}`.text(),
  };

  for (let i = 0; i < items.length; i++) {
    await processItem(items[i], i, items.length, ctx);
  }

  console.log();
  console.log(`=> All ${items.length} item(s) processed.`);
  console.log("=> Review the changes and commit when ready.");
  rl.close();
}

main();
