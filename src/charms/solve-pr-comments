#!/usr/bin/env bun

import { $ } from "bun";
import * as readline from "readline";

// --- Constants ---

const CLAUDE_ALLOWED_TOOLS = [
  "Read",
  "Edit",
  "Write",
  "Bash(git diff:*)",
  "Bash(git log:*)",
  "Bash(git status:*)",
  "Grep",
].join(",");

const CLAUDE_COMMIT_ALLOWED_TOOLS = [
  "Bash(git diff:*)",
  "Bash(git log:*)",
  "Bash(git status:*)",
  "Bash(git commit:*)",
].join(",");

const SEPARATOR = "=".repeat(44);

// --- Colors (Nordic palette via Bun.color) ---

const RESET = "\x1b[0m";
const BOLD = "\x1b[1m";

function ansi(hex: string): string {
  return Bun.color(hex, "ansi") ?? "";
}

const C = {
  header: ansi("#88C0D0"),  // blue2 — frost
  success: ansi("#A3BE8C"), // green
  warn: ansi("#EBCB8B"),    // yellow
  error: ansi("#BF616A"),   // red
  info: ansi("#60728A"),    // gray5 — dim
  prompt: ansi("#D08770"),  // orange
  label: ansi("#B48EAD"),   // magenta
};

function paint(color: string, text: string): string {
  return `${color}${text}${RESET}`;
}

function logHeader(text: string): void {
  console.log(paint(C.header + BOLD, text));
}

function logInfo(text: string): void {
  console.log(paint(C.info, text));
}

function logSuccess(text: string): void {
  console.log(paint(C.success, text));
}

function logWarn(text: string): void {
  console.warn(paint(C.warn, text));
}

function logError(text: string): void {
  console.error(paint(C.error, text));
}

function logSeparator(): void {
  console.log(paint(C.info, SEPARATOR));
}

// --- Types ---

interface RawComment {
  body: string;
  author: { login: string };
  createdAt: string;
}

interface RawThread {
  id: string;
  isResolved: boolean;
  isOutdated: boolean;
  path: string;
  line: number | null;
  originalLine: number | null;
  comments: {
    pageInfo: { hasNextPage: boolean };
    nodes: RawComment[];
  };
}

type ReviewThreadItem = {
  kind: "thread";
  id: string;
  path: string;
  line: number | null;
  comments: string;
};

type GeneralCommentItem = {
  kind: "comment";
  comments: string;
};

type Item = ReviewThreadItem | GeneralCommentItem;

type PRContext = {
  num: number;
  repo: string;
  diff: string;
};

// --- Helpers ---

async function confirmUser(question: string): Promise<boolean> {
  const colored = paint(C.prompt, question);
  const rl = readline.createInterface({ input: process.stdin, output: process.stdout });
  return new Promise((resolve) => {
    rl.question(colored, (answer) => {
      rl.close();
      const a = answer.trim().toLowerCase();
      resolve(a !== "n" && a !== "no");
    });
  });
}

async function runClaude(prompt: string, allowedTools: string = CLAUDE_ALLOWED_TOOLS): Promise<number> {
  const proc = Bun.spawn(
    [
      "claude",
      "--dangerously-skip-permissions",
      "--print",
      prompt,
      "--model",
      "sonnet",
      "--allowedTools",
      allowedTools,
    ],
    { stdout: "pipe", stderr: "inherit", stdin: "ignore" }
  );

  const indent = paint(C.info, "  ");
  let buffer = "";
  for await (const chunk of proc.stdout) {
    buffer += Buffer.from(chunk).toString("utf8");
    const lines = buffer.split("\n");
    buffer = lines.pop() ?? "";
    for (const line of lines) console.log(`${indent}${line}`);
  }
  if (buffer) console.log(`${indent}${buffer}`);

  await proc.exited;
  const code = proc.exitCode ?? 0;
  if (code !== 0) {
    logWarn(`=> Warning: Claude exited with code ${code}. Changes may be incomplete.`);
  }
  return code;
}

function extractFileDiff(fullDiff: string, filePath: string): string {
  const sections = fullDiff.split(/(?=^diff --git )/m);
  const match = sections.find((s) => s.includes(`b/${filePath}`));
  return match ?? `(no diff found for ${filePath})`;
}

function buildCommitPrompt(stagedDiff: string, recentLog: string, ctx: PRContext): string {
  return `# Role
You are an expert software engineer creating a git commit for staged changes on Pull Request #${ctx.num} in ${ctx.repo}.

# Context
## Recent Commits (follow this style)
\`\`\`
${recentLog}
\`\`\`

## Staged Changes (\`git diff --cached\`)
\`\`\`diff
${stagedDiff}
\`\`\`

# Task
1. Analyze the staged changes.
2. Write a concise commit message that matches the tone and format of the recent commits above.
3. Run \`git commit -m "<message>"\` to create the commit.

# Constraints
- Commit ONLY what is already staged. Do NOT run \`git add\`.
- Keep the subject line under 72 characters.
- If staging is empty, print "No staged changes" and do nothing.
- Do not amend or rewrite existing commits.

# Output Format
1. Brief reasoning (1-2 lines) explaining your chosen message.
2. The commit command you ran and its result.`;
}

async function runCommitMenu(ctx: PRContext): Promise<void> {
  const status = (await $`git status --short`.text()).trim();
  if (!status) {
    logInfo("=> No changes to commit. Skipping commit menu.");
    return;
  }

  console.log();
  logHeader("=> Git status:");
  console.log(status);
  console.log();

  if (!await confirmUser("=> Create a commit for staged files? [Y/n] ")) {
    logInfo("=> Skipped commit.");
    return;
  }

  const stagedDiff = (await $`git diff --cached`.text()).trim();
  if (!stagedDiff) {
    logWarn("=> Nothing is staged. Stage files with `git add` first, then re-run.");
    return;
  }

  const recentLog = (await $`git log -10 --oneline`.text()).trim();

  console.log();
  logHeader("=> Generating commit with Claude...");
  const code = await runClaude(
    buildCommitPrompt(stagedDiff, recentLog, ctx),
    CLAUDE_COMMIT_ALLOWED_TOOLS,
  );
  if (code === 0) {
    logSuccess("=> Commit step finished.");
  }
}

function buildPrompt(contextBlock: string): string {
  return `# Role
You are an expert Senior Staff Software Engineer. You possess deep expertise in automated code refactoring, software architecture, and root cause analysis.

# Context
${contextBlock}

# Task
Implement a robust engineering solution based on the feedback received from the review comment.

## Analysis & Resolution Steps
1. **Analyze the Claim:** Examine the feedback in the context of the codebase and the diff.
2. **Critically Evaluate (Mandatory):**
   - **Verify Validity:** Do not assume the comment is factually correct. Challenge the premise.
   - **Check Constraints:** Ensure the suggested change does not violate existing logic or introduce regressions.
3. **Determine the Solution:**
   - If the issue is valid, identify the **root cause** and which file(s) need to change.
   - **Solve, Don't Just Obey:** If the comment suggests a specific implementation that is suboptimal, insecure, or hacky, ignore the suggestion and implement the **industry-standard best practice**.
   - If the comment is invalid or already addressed, explain why and skip the change.
4. **Implement:** Apply the specific code changes to the codebase.

# Constraints
- Prioritize code stability and system integrity over blind compliance to the reviewer's specific instructions.
- Only modify the file(s) relevant to the feedback. Do not refactor unrelated code.

# Output Format
1. **Logic Verification:** A brief analysis (2-3 lines) explaining whether the comment was valid and why you chose the specific solution.
2. **Code Fix:** Apply the necessary changes to the codebase.`;
}

async function resolveThreadOnGitHub(threadId: string): Promise<boolean> {
  try {
    const result = await $`gh api graphql -f query=${`
      mutation($threadId: ID!) {
        resolveReviewThread(input: { threadId: $threadId }) {
          thread {
            isResolved
          }
        }
      }
    `} -f threadId=${threadId}`.json();
    return result.data?.resolveReviewThread?.thread?.isResolved === true;
  } catch {
    return false;
  }
}

async function buildContext(item: Item, ctx: PRContext): Promise<string> {
  if (item.kind === "thread") {
    const file = Bun.file(item.path);
    const fileContent = (await file.exists()) ? await file.text() : "";
    const fileDiff = extractFileDiff(ctx.diff, item.path);
    const lineContext = item.line != null
      ? `**Line:** ${item.line}`
      : `**Scope:** Entire file (no specific line)`;

    return `You are resolving code review feedback on Pull Request #${ctx.num} in the repository ${ctx.repo}.

## Review Thread
- **File:** ${item.path}
- ${lineContext}

### Reviewer Comments
${item.comments}

### Current File Content
\`\`\`
${fileContent}
\`\`\`

### Relevant PR Diff
${fileDiff}`;
  }

  return `You are resolving general PR feedback on Pull Request #${ctx.num} in the repository ${ctx.repo}.
This comment is not tied to a specific file or line — it is a high-level review comment about the PR as a whole.

### Reviewer Comment
${item.comments}

### Relevant PR Diff
${ctx.diff}`;
}

async function processItem(item: Item, index: number, total: number, ctx: PRContext): Promise<void> {
  console.log();
  console.log();
  logSeparator();

  const label = item.kind === "thread"
    ? `Thread on ${item.line != null ? `${item.path}:${item.line}` : item.path}`
    : "General PR comment";

  const counter = paint(C.label, `[${index + 1}/${total}]`);
  console.log(`${paint(C.header, "=>")} ${counter} ${paint(C.header + BOLD, label)}`);
  console.log();
  console.log(paint(C.label, item.kind === "thread" ? "Comments:" : "Comment:"));
  for (const line of item.comments.split("\n")) {
    console.log(`  ${line}`);
  }
  logSeparator();
  console.log();

  const actionLabel = item.kind === "thread" ? "Resolve this thread" : "Address this comment";
  if (!await confirmUser(`=> ${actionLabel}? [Y/n] `)) {
    logInfo("=> Skipped.");
    return;
  }

  console.log();
  await runClaude(buildPrompt(await buildContext(item, ctx)));

  await runCommitMenu(ctx);

  if (item.kind === "thread") {
    console.log();
    if (await confirmUser("=> Mark this thread as resolved on GitHub? [Y/n] ")) {
      const resolved = await resolveThreadOnGitHub(item.id);
      if (resolved) {
        logSuccess("=> Thread marked as resolved on GitHub.");
      } else {
        logWarn("=> Warning: could not resolve thread on GitHub.");
      }
    }
  }

  console.log();
  logSuccess(`=> Done with item [${index + 1}/${total}].`);
}

// --- Main ---

async function main(): Promise<void> {
  let repo: string;
  try {
    repo = (await $`gh repo view --json nameWithOwner --jq '.nameWithOwner'`.text()).trim();
  } catch {
    logError("=> Error: could not determine repo. Are you inside a GitHub repository?");
    process.exit(1);
  }
  console.log(`${paint(C.header, "=> Repo:")} ${paint(C.label, repo)}`);

  logInfo("=> Fetching PR number...");
  let prNum: number;
  try {
    const raw = (await $`gh pr view --json number --jq '.number'`.text()).trim();
    prNum = parseInt(raw);
    if (!Number.isFinite(prNum) || prNum <= 0) throw new Error("invalid PR number");
  } catch {
    logError(
      "=> Error: could not parse a valid PR number from `gh pr view`.\n" +
      "   Make sure you are on a branch with an open PR and that `gh auth status` is authenticated."
    );
    process.exit(1);
  }
  console.log(`${paint(C.header, "=> PR")} ${paint(C.label, `#${prNum}`)}`);
  console.log();

  logInfo("=> Fetching unresolved review threads and general comments...");
  const [owner, repoName] = repo.split("/");

  const threadsResult = await $`gh api graphql -f query=${`
    query($owner: String!, $repo: String!, $pr: Int!) {
      repository(owner: $owner, name: $repo) {
        pullRequest(number: $pr) {
          reviewThreads(first: 100) {
            pageInfo { hasNextPage }
            nodes {
              id
              isResolved
              isOutdated
              path
              line
              originalLine
              comments(first: 10) {
                pageInfo { hasNextPage }
                nodes {
                  body
                  author { login }
                  createdAt
                }
              }
            }
          }
          comments(first: 100) {
            nodes {
              body
              author { login }
              createdAt
            }
          }
        }
      }
    }
  `} -f owner=${owner} -f repo=${repoName} -F pr=${prNum}`.json();

  if (threadsResult.errors?.length) {
    logError("=> GraphQL error fetching review threads:");
    for (const e of threadsResult.errors) logError(`   ${e.message}`);
    process.exit(1);
  }

  const pr = threadsResult.data.repository.pullRequest;

  if (pr.reviewThreads.pageInfo.hasNextPage) {
    logWarn("=> Warning: this PR has more than 100 review threads. Only the first 100 will be processed.");
  }

  for (const thread of pr.reviewThreads.nodes as RawThread[]) {
    if (thread.comments.pageInfo.hasNextPage) {
      logWarn(`=> Warning: thread on ${thread.path} has more than 10 comments. Only the first 10 are included in the prompt.`);
    }
  }

  const unresolvedThreads: Item[] = (pr.reviewThreads.nodes as RawThread[])
    .filter((t) => !t.isResolved && !t.isOutdated)
    .map((t) => ({
      kind: "thread" as const,
      id: t.id,
      path: t.path,
      line: t.line ?? t.originalLine ?? null,
      comments: t.comments.nodes
        .map((c) => `**${c.author.login}:** ${c.body}`)
        .join("\n"),
    }));

  const generalComments: Item[] = (pr.comments.nodes as RawComment[]).map((c) => ({
    kind: "comment" as const,
    comments: `**${c.author.login}:** ${c.body}`,
  }));

  const items: Item[] = [...unresolvedThreads, ...generalComments];

  if (items.length === 0) {
    logSuccess("=> No review comments found. Nothing to do.");
    process.exit(0);
  }

  console.log(
    `${paint(C.header, "=> Found")} ${paint(C.label, String(unresolvedThreads.length))}` +
    `${paint(C.header, " unresolved review thread(s) and ")}` +
    `${paint(C.label, String(generalComments.length))}${paint(C.header, " general comment(s).")}`
  );

  logInfo("=> Fetching PR diff...");
  const ctx: PRContext = {
    num: prNum,
    repo,
    diff: await $`gh pr diff ${prNum}`.text(),
  };

  for (let i = 0; i < items.length; i++) {
    await processItem(items[i], i, items.length, ctx);
  }

  console.log();
  logSuccess(`=> All ${items.length} item(s) processed.`);
  logInfo("=> Review the changes and commit when ready.");
}

main();
